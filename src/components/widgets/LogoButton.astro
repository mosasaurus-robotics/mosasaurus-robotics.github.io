---
import Link from '~/components/base/Link.astro'
import { withBasePath } from '~/utils/path'
import { SITE } from '~/config'
---

<Link
  class="select-none op-transition"
  href={withBasePath('/')}
  aria-label={SITE.author}
  aria-current={Astro.url.pathname === `${withBasePath('/')}` ? 'page' : false}
>
  <div class="logo-container">
    <img
      class="site-logo site-logo-light"
      src={withBasePath('/logo_light.svg')}
      alt=""
      width="180"
      height="60"
      decoding="async"
    />
    <img
      class="site-logo site-logo-dark"
      src={withBasePath('/logo_dark.svg')}
      alt=""
      width="180"
      height="60"
      decoding="async"
    />
  </div>
</Link>

<style>
  .logo-container {
    display: flex;
    align-items: center;
    height: 3rem;
  }

  .site-logo {
    display: block;
    width: auto;
    height: 3rem;
    max-width: min(18rem, 48vw);
    object-fit: contain;
  }

  .site-logo-dark {
    display: none;
  }

  :global(html.dark) .site-logo-light {
    display: none;
  }

  :global(html.dark) .site-logo-dark {
    display: block;
  }

  @media (max-width: 767.9px) {
    .logo-container {
      height: 2.35rem;
      margin-top: 0.125rem;
    }

    .site-logo {
      height: 2.35rem;
      max-width: min(12rem, 42vw);
    }
  }
</style>
